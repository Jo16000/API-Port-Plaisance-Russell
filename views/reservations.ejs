<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gestion des Réservations - Port Russell</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="main-header">
        <nav class="nav-menu">
            <a href="/dashboard" class="nav-link">← Tableau de Bord</a>
            <a href="/views/catways" class="nav-link">Gestion Catways</a>
            <a href="/views/users" class="nav-link">Gestion Utilisateurs</a>
            <a href="/logout" class="btn-logout">Se déconnecter</a>
        </nav>
    </header>

    <main class="content-container">
        <h1>Gestion des Réservations de Plaisance</h1>

        <section class="form-section">
            <h2>Créer une nouvelle réservation d'amarrage</h2>
            <form id="reservationForm" method="POST" class="vertical-form">
                <div class="form-group">
                    <label>Sélectionner le Catway disponible :</label>
                    <select id="catwaySelect" required onchange="updateFormAction(this.value)">
                        <option value="">-- Choisir un emplacement --</option>
                        <% catways.forEach(catway => { %>
                            <option value="<%= catway.catwayNumber %>">Catway N° <%= catway.catwayNumber %> (<%= catway.catwayType %>)</option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Nom du Client :</label>
                        <input type="text" name="clientName" placeholder="Ex: Jean Dupont" required>
                    </div>
                    <div class="form-group">
                        <label>Nom du Navire :</label>
                        <input type="text" name="boatName" placeholder="Ex: L'Audacieux" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Date d'entrée :</label>
                        <input type="date" name="startDate" required>
                    </div>
                    <div class="form-group">
                        <label>Date de sortie :</label>
                        <input type="date" name="endDate" required>
                    </div>
                </div>

                <button type="submit" class="btn-add">Valider l'attribution d'emplacement</button>
            </form>
        </section>

        <section class="list-section">
            <h2>Historique et Plannings des Amarrages</h2>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Emplacement</th>
                        <th>Plaisancier</th>
                        <th>Bateau</th>
                        <th>Période de Réservation</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% reservations.forEach(res => { %>
                        <tr>
                            <td><span class="badge">N° <%= res.catwayNumber %></span></td>
                            <td><%= res.clientName %></td>
                            <td><em><%= res.boatName %></em></td>
                            <td>Du <%= new Date(res.startDate).toLocaleDateString('fr-FR') %> au <%= new Date(res.endDate).toLocaleDateString('fr-FR') %></td>
                            <td>
                                <form action="/catways/<%= res.catwayNumber %>/reservations/<%= res._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Annuler cette réservation ?')">
                                    <button type="submit" class="btn-delete">Annuler</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </section>
    </main>

    <script>
        function updateFormAction(catwayNumber) {
            const form = document.getElementById('reservationForm');
            if(catwayNumber) {
                form.action = '/catways/' + catwayNumber + '/reservations';
            } else {
                form.action = '';
            }
        }
    </script>
</body>
</html>