<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Port de Plaisance Russell - Connexion</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="login-container">
        <h1>Port de Plaisance Russell</h1>
        <p class="description">
            Bienvenue sur l'application de gestion de la capitainerie du Port de Russell. 
            Cette interface privée permet de gérer l'état des catways, de planifier les réservations 
            et de configurer les accès des agents de bord.
        </p>

        <% if (error) { %>
            <div class="alert error"><%= error %></div>
        <% } %>

        <form action="/login" method="POST" class="login-form">
            <div class="form-group">
                <label for="email">Adresse email de l'agent :</label>
                <input type="email" id="email" name="email" required placeholder="agent@port-russell.fr">
            </div>

            <div class="form-group">
                <label for="password">Mot de passe :</label>
                <input type="password" id="password" name="password" required placeholder="••••••••">
            </div>

            <button type="submit" class="btn-submit">Se connecter au tableau de bord</button>
        </form>

        <div class="login-footer">
            <a href="/docs" target="_blank" class="link-docs">🌐 Accéder à la Documentation de l'API</a>
        </div>
    </div>
</body>
</html>